# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# env — never commit real secrets (commit .env.example only)
.env
.env.local
.env*.local

# drizzle generated artifacts (migrations/ are hand-authored and committed)
/drizzle

# logs / os
*.log
npm-debug.log*
.DS_Store

# typescript
*.tsbuildinfo

# client-owned test content (BRIEF §11) — don't commit raw HTML/audio
/samples/*.html
/samples/*.htm
/samples/*.mp3
/samples/*.m4a
# ...and the same content dropped in the repo root (audio anywhere)
*.mp3
*.m4a
/listening-test.html
/design-*.html

# bando design system handoff — reference only, recreated in src/ + app/, not shipped as-is
/design-drop/

# throwaway ops / prod-mutator scripts — run via `npx tsx` then discarded, NEVER commit.
# Committing a prod-mutator (e.g. _restore_prod.ts, _set_tiers.ts) is a footgun: it could
# be run against the wrong env (cf. the db:down incident). Legit scripts have no leading
# underscore (verify.ts, migrate.ts, setup-*.ts, smoke-*.ts).
/scripts/_*

# local tooling worktrees / cache — not project source
/.claude/
# impeccable critique snapshots — local design-review archive, not shipped source
/.impeccable/

# QA-партии импорта: исходные HTML с ключами ответов — не для гита
.qa-import/

# session scratch
.codex-tmp/
/photo_*.jpg

.vercel
.env*
