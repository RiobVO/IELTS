# dependencies
/node_modules
/.pnp
.pnp.*

# next.js
/.next/
/out/
next-env.d.ts

# production
/build

# env — never commit real secrets (commit .env.example only)
.env
.env.local
.env*.local

# drizzle generated artifacts (migrations/ are hand-authored and committed)
/drizzle

# logs / os
*.log
npm-debug.log*
.DS_Store

# typescript
*.tsbuildinfo

# client-owned test content (BRIEF §11) — don't commit raw HTML/audio
/samples/*.html
/samples/*.htm
/samples/*.mp3
/samples/*.m4a
# ...and the same content dropped in the repo root (audio anywhere)
*.mp3
*.m4a
/listening-test.html
/design-*.html
