# Copy to .env.local and fill in. Never commit .env.local.
# `npm run verify` and the server DB client fail fast if any required var is missing.

# --- Server (secrets — never exposed to the browser) ---

# Supabase project URL, e.g. https://<ref>.supabase.co
SUPABASE_URL=

# Supabase anon (public) key — safe for the browser; DB access gated by RLS.
SUPABASE_ANON_KEY=

# Supabase service-role key — SERVER ONLY. Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string used by Drizzle / migrations (the Supabase DB or a local Postgres).
# Local docker example: postgresql://postgres:postgres@localhost:5432/postgres
DATABASE_URL=

# --- Browser (must use the NEXT_PUBLIC_ prefix; same values as SUPABASE_URL / SUPABASE_ANON_KEY) ---
# Used by the @supabase/ssr auth clients on the client side.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
