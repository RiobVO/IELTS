# Copy to .env.local and fill in. Never commit .env.local.
# `npm run verify` and the server DB client fail fast if any required var is missing.

# --- Server (secrets — never exposed to the browser) ---

# Supabase project URL, e.g. https://<ref>.supabase.co
SUPABASE_URL=

# Supabase anon (public) key — safe for the browser; DB access gated by RLS.
SUPABASE_ANON_KEY=

# Supabase service-role key — SERVER ONLY. Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# App runtime DB. On Supabase use the transaction pooler (port 6543).
# Local docker example: postgresql://postgres:postgres@localhost:5432/postgres
DATABASE_URL=

# Migrations DB. On Supabase use the session pooler (port 5432). Migrations prefer
# this over DATABASE_URL. Locally it can equal DATABASE_URL (or be left unset).
DIRECT_URL=

# --- Browser (must use the NEXT_PUBLIC_ prefix; same values as SUPABASE_URL / SUPABASE_ANON_KEY) ---
# Used by the @supabase/ssr auth clients on the client side.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Canonical public origin (invite / referral links) — OPTIONAL ---
# Absent => absolute links fall back to the incoming request Host. Set it to the
# canonical app origin (e.g. https://app.example.com) so invite/referral URLs are
# anchored to a trusted domain instead of a possibly-spoofed Host header. PUBLIC.
NEXT_PUBLIC_SITE_URL=

# --- Product analytics (PostHog, BRIEF §11) — OPTIONAL ---
# Absent => analytics is a silent no-op (fail-open; telemetry is non-critical, unlike
# the required vars above). The project key is PUBLIC (ingest-only) and safe in the
# browser; the SAME key serves both the browser SDK and server-side capture. Host
# defaults to PostHog US cloud — switch to https://eu.i.posthog.com for EU residency.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Error monitoring (Sentry, BRIEF §11) — OPTIONAL ---
# Absent => Sentry is a silent no-op (fail-open; like PostHog above). The DSN is
# PUBLIC (ingest-only) and safe in the browser; the SAME DSN serves browser,
# server and edge runtimes. Source-map upload (readable stack traces) needs an
# auth token + org/project and is deferred until launch — errors are still
# captured without it (minified traces). ENVIRONMENT defaults to NODE_ENV.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=

# --- Payment providers (BRIEF §4.8) — OPTIONAL ---
# Absent => the webhook for that provider runs in stub/dev mode (signature check
# skipped + logged) so the lifecycle is testable before merchant onboarding.
# SERVER-ONLY secrets, read via paymentSecret() in src/env.ts.
PAYME_MERCHANT_KEY=
CLICK_SECRET_KEY=
UZUM_SECRET_KEY=

# --- Cron / downgrade job secret (BRIEF §11) — OPTIONAL, but fail-closed ---
# Guards the cron expiry endpoint (Bearer auth) and doubles as the Speaking
# internal secret (speakingInternalSecret() reuses it). Absent => the endpoint
# refuses all calls rather than running unauthenticated. Set any random string
# (e.g. `openssl rand -hex 32`).
CRON_SECRET=

# --- Telegram content-import bot (OPTIONAL, admin channel) ---
# Absent => the bot is disabled (its webhook is a no-op). SERVER-ONLY secrets.
# TELEGRAM_BOT_TOKEN     — from @BotFather.
# TELEGRAM_ADMIN_IDS     — comma-separated Telegram user IDs allowed to import.
#                          The bot writes via the owner DB path, so this allow-list
#                          IS the security boundary — keep it tight.
# TELEGRAM_WEBHOOK_SECRET — random string; also passed to setWebhook and checked
#                          against the X-Telegram-Bot-Api-Secret-Token header.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_IDS=
TELEGRAM_WEBHOOK_SECRET=

# --- Telegram channel link (OPTIONAL) ---
# Student-facing Telegram channel shown as a CTA on the empty practice catalog
# (content-wipe funnel). SERVER-ONLY (not NEXT_PUBLIC_*) — read in page.tsx and
# passed down as a prop. Absent => the CTA is simply not rendered.
TELEGRAM_CHANNEL_URL=

# --- Anti-bot on signup (Cloudflare Turnstile, BRIEF §11) — OPTIONAL ---
# Absent => the captcha is OFF (fail-open; signup works without it). Activates only
# when BOTH are set. NEXT_PUBLIC_TURNSTILE_SITE_KEY is PUBLIC (renders the widget in
# the browser); TURNSTILE_SECRET_KEY is SERVER-ONLY (used for siteverify). Get both
# from the Cloudflare Turnstile dashboard.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- AI Writing Lab (Phase 3, essay Task 2) — OPTIONAL ---
# Absent => Writing Lab evaluation is DISABLED (the app boots; R/L core stays
# LLM-free regardless). Activates only when BOTH are set. SERVER-ONLY secrets,
# used only inside src/lib/writing/. WRITING_EVAL_MODEL is the Gemini Flash model
# id — fill it ONLY after a candidate passes the offline benchmark (±0.5 band
# accuracy gate); until then leave blank so the feature stays off in product.
GEMINI_API_KEY=
WRITING_EVAL_MODEL=

# Internal secret guarding the server-to-server /api/writing/evaluate route. The
# create-submission action calls evaluate fire-and-forget with this Bearer; the
# route fails closed without it (users must never reach the evaluator directly —
# cost-abuse via tokens). Set any random string (e.g. `openssl rand -hex 32`).
WRITING_INTERNAL_SECRET=

# --- L1 (RU) explanations generation (content step, migration 0050) — OPTIONAL ---
# Absent => content publishes without RU explanations (answer_key.explanation_ru stays
# NULL); the app boots either way, import/grading are unaffected. Activates only when
# BOTH GEMINI_API_KEY (above) and L1_GEN_MODEL are set. Reuses CRON_SECRET as the
# internal route's Bearer — no dedicated secret. SERVER-ONLY.
L1_GEN_MODEL=

# --- AI Speaking Lab (Phase 3, Part 2) — OPTIONAL ---
# Feature hidden until SPEAKING_EVAL_MODEL is set (speakingEvalConfig() -> null).
# Reuses GEMINI_API_KEY + SUPABASE_SERVICE_ROLE_KEY (server-only audio download).
# The knobs below have safe in-code defaults; override per environment.
SPEAKING_EVAL_MODEL=
SPEAKING_AUDIO_RETENTION_DAYS=7
SPEAKING_UPLOAD_TTL_SEC=60
SPEAKING_STALE_MS=120000

# OpenAI key for Whisper STT — used ONLY to fetch accurate word timings for the
# Speaking transcript karaoke-sync, never for scoring (Gemini owns that). Absent
# => the sync feature degrades to a static transcript; the rest of Speaking eval
# is unaffected. SERVER-ONLY secret.
OPENAI_API_KEY=

# --- Weekly digest email (OPTIONAL) ---
# Absent => the digest job is DISABLED (no-op, no cron misfire). Activates only when
# BOTH EMAIL_PROVIDER_API_KEY and EMAIL_FROM are set. SERVER-ONLY secret (Brevo API key).
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM=
EMAIL_FROM_NAME=

# --- Stateful e2e gate (OPTIONAL, fail-closed) ---
# `npm run test:e2e` includes WRITE specs (signup.spec.ts, smoke.spec.ts) that
# create real users and attempt rows via service-role, against whatever
# DATABASE_URL/DIRECT_URL points at (no staging env). Absent => those specs are
# skipped and global-setup refuses to provision a user. Set to "1" to opt in —
# the gate ALSO refuses even with this flag set if DATABASE_URL/DIRECT_URL
# targets the prod Supabase project ref (see e2e/stateful-gate.ts).
ALLOW_STATEFUL_E2E=

# --- Local verify gate ---
# `npm run verify` is DESTRUCTIVE (drops/recreates the public schema) — point it at a
# THROWAWAY local Postgres, NEVER your Supabase DB. It refuses a non-local target
# unless VERIFY_ALLOW_REMOTE=1. Start one with `npm run docker:db`.
VERIFY_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
