# Copy to .env.local and fill in. Never commit .env.local.
# `npm run verify` and the server DB client fail fast if any required var is missing.

# --- Server (secrets — never exposed to the browser) ---

# Supabase project URL, e.g. https://<ref>.supabase.co
SUPABASE_URL=

# Supabase anon (public) key — safe for the browser; DB access gated by RLS.
SUPABASE_ANON_KEY=

# Supabase service-role key — SERVER ONLY. Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# App runtime DB. On Supabase use the transaction pooler (port 6543).
# Local docker example: postgresql://postgres:postgres@localhost:5432/postgres
DATABASE_URL=

# Migrations DB. On Supabase use the session pooler (port 5432). Migrations prefer
# this over DATABASE_URL. Locally it can equal DATABASE_URL (or be left unset).
DIRECT_URL=

# --- Browser (must use the NEXT_PUBLIC_ prefix; same values as SUPABASE_URL / SUPABASE_ANON_KEY) ---
# Used by the @supabase/ssr auth clients on the client side.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Product analytics (PostHog, BRIEF §11) — OPTIONAL ---
# Absent => analytics is a silent no-op (fail-open; telemetry is non-critical, unlike
# the required vars above). The project key is PUBLIC (ingest-only) and safe in the
# browser; the SAME key serves both the browser SDK and server-side capture. Host
# defaults to PostHog US cloud — switch to https://eu.i.posthog.com for EU residency.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# --- Local verify gate ---
# `npm run verify` is DESTRUCTIVE (drops/recreates the public schema) — point it at a
# THROWAWAY local Postgres, NEVER your Supabase DB. It refuses a non-local target
# unless VERIFY_ALLOW_REMOTE=1. Start one with `npm run docker:db`.
VERIFY_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
