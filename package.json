{
  "name": "ielts-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "IELTS preparation platform — Phase 1 scaffold (Next.js + Drizzle + Supabase/Postgres)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx scripts/migrate.ts up",
    "db:down": "tsx scripts/migrate.ts down --all",
    "db:up:local": "tsx scripts/migrate.ts up --local",
    "db:down:local": "tsx scripts/migrate.ts down --all --local",
    "db:status": "tsx scripts/migrate.ts status",
    "db:bootstrap": "tsx scripts/migrate.ts bootstrap",
    "db:migrate:test": "tsx scripts/migrate-test.ts up",
    "db:status:test": "tsx scripts/migrate-test.ts status",
    "test:hosted:posture": "tsx scripts/rls-posture-test.ts",
    "test:hosted:rls": "tsx scripts/rls-http-test.ts",
    "test:hosted:storage:setup": "tsx scripts/setup-test-storage.ts",
    "test:hosted:storage": "tsx scripts/storage-contract-test.ts",
    "docker:db": "docker compose up -d db",
    "docker:db:down": "docker compose down -v",
    "verify": "tsx scripts/verify.ts",
    "storage:verify": "tsx scripts/smoke-speaking-storage.ts",
    "import": "tsx scripts/import-file.ts",
    "import:vocab": "tsx scripts/import-vocab.ts",
    "test": "vitest run",
    "test:db": "vitest run --config vitest.config.db.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:stateful": "tsx scripts/run-stateful-e2e.ts"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@sentry/nextjs": "^10.58.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.1",
    "@vercel/speed-insights": "^2.0.0",
    "cheerio": "^1.2.0",
    "drizzle-orm": "^0.45.2",
    "next": "^15.5.0",
    "postgres": "^3.4.5",
    "posthog-js": "^1.386.8",
    "posthog-node": "^5.37.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^4.1.10",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.30.1",
    "jsdom": "^29.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
